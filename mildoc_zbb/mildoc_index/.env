# mildoc index

# minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mildoc
MINIO_REGION=minio
MINIO_USE_VIRTUAL_HOST=false
MINIO_USE_SSL=false

# 监听 MinIO 桶事件后，并行处理文档（解析+embedding+写 Milvus）的线程池大小
# 默认取 CPU 核数；解析偏 CPU，建议别设太大，按机器核数从 2~4 起步调优
# MINIO_PROCESS_MAX_WORKERS=4


