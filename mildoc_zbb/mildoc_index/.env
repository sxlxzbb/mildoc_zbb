# milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=admin123
MILVUS_DATABASE=mildoc
MILVUS_COLLECTION=mildoc_collection
MILVUS_INDEX_NAME=mildoc_index
MILVUS_VECTOR_DIM=768

# bailian embedding llm
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ENBEDDING_MODEL=text-embedding-v4


# MinerU
# 启用MinerU前，先安装： uv add mineru[core]==2.7.0
# MINERU_SERVER_URL=http://127.0.0.1:8000